# AI Generation (Google Gemini API)
# Get your API key from https://ai.google.dev/
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# File Upload (UploadThing) - Optional
# Get your token from https://uploadthing.com/
UPLOADTHING_TOKEN=your_uploadthing_token_here

# Authentication
JWT_SECRET=your_jwt_secret_here_min_32_chars
ADMIN_SECRET=your_secure_admin_password
NEXT_PUBLIC_ADMIN_EMAIL=admin@inkycards.com

# Stripe (Test Mode)
# Get your keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inky_cards?schema=public

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
